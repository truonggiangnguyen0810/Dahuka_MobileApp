<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <include layout="@layout/taskbar" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#008037" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|center_horizontal"
            android:paddingStart="6dp"
            android:paddingTop="8dp"
            android:paddingEnd="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/o_nhap_thong_tin"
                android:elevation="2dp"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập thông tin cá nhân"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Ô nhập số điện thoại -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="21dp"
                        android:src="@drawable/ic_phone"
                        app:tint="#8A8F98" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:layout_marginStart="14dp"
                        android:background="#E0E5EC" />

                    <EditText
                        android:id="@+id/edtSoDienThoai"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Số điện thoại"
                        android:inputType="phone"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="#111827"
                        android:textColorHint="#A7B1C2"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="21dp"
                        android:src="@drawable/ic_user"
                        app:tint="#8A8F98" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:layout_marginStart="14dp"
                        android:background="#E0E5EC" />

                    <EditText
                        android:id="@+id/edtHoTen"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Tên người dùng"
                        android:inputType="textPersonName"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="#111827"
                        android:textColorHint="#A7B1C2"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="21dp"
                        android:src="@drawable/ic_email"
                        app:tint="#8A8F98" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:layout_marginStart="14dp"
                        android:background="#E0E5EC" />

                    <EditText
                        android:id="@+id/edtEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Nhập Email của bạn"
                        android:inputType="textEmailAddress"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="#111827"
                        android:textColorHint="#A7B1C2"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="21dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="#8A8F98" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:layout_marginStart="14dp"
                        android:background="#E0E5EC" />

                    <EditText
                        android:id="@+id/edtNgaySinh"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="dd/mm/yyyy (không bắt buộc)"
                        android:inputType="date"
                        android:focusable="false"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="#111827"
                        android:textColorHint="#A7B1C2"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="21dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#8A8F98" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:layout_marginStart="14dp"
                        android:background="#E0E5EC" />

                    <EditText
                        android:id="@+id/edtMatKhau"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Mật khẩu"
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="#111827"
                        android:textColorHint="#A7B1C2"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:background="#E0E5EC" />

                    <ImageView
                        android:id="@+id/imgAnHienMatKhau"
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="13dp"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_eye"
                        app:tint="#C5CAD3" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="21dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#8A8F98" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:layout_marginStart="14dp"
                        android:background="#E0E5EC" />

                    <EditText
                        android:id="@+id/edtXacNhanMatKhau"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Xác nhận mật khẩu"
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:textColor="#111827"
                        android:textColorHint="#A7B1C2"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="25dp"
                        android:background="#E0E5EC" />

                    <ImageView
                        android:id="@+id/imgAnHienXacNhanMatKhau"
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:layout_marginStart="13dp"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_eye"
                        app:tint="#C5CAD3" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnDangKy"
                    android:layout_width="132dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="#1F2937"
                    android:text="Đăng ký"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />

                <TextView
                    android:id="@+id/tvPasswordNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:lineSpacingExtra="3dp"
                    android:text="* Lưu ý: Mật khẩu tối thiểu mười (10) ký tự, ít nhất một chữ cái viết hoa, một chữ cái viết thường, một số và một ký tự đặc biệt (@$!*?&amp;)."
                    android:textColor="#4B5563"
                    android:textSize="12sp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
