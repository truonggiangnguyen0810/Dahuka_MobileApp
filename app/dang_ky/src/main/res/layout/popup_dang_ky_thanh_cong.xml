<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/nen_popup_dang_ky_thanh_cong"
    android:paddingStart="24dp"
    android:paddingTop="20dp"
    android:paddingEnd="24dp"
    android:paddingBottom="22dp">

    <ImageView
        android:id="@+id/imgThanhCong"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:contentDescription="Dang ky thanh cong"
        android:src="@drawable/ic_dang_ky_thanh_cong" />

    <TextView
        android:id="@+id/txtThongBaoThanhCong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Chúc mừng quý khách đã đăng ký thành công"
        android:textColor="#8C94A3"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnTiepTucPopup"
        android:layout_width="140dp"
        android:layout_height="40dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/nut_popup_tiep_tuc"
        android:text="Tiếp tục"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>