<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <!-- Logo DAHUKA -->
    <ImageView
        android:id="@+id/imgLogoDahuka"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:contentDescription="Logo DAHUKA"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_dahuka"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tên logo -->
    <TextView
        android:id="@+id/txtTenLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="DAHUKA"
        android:textColor="#007A5A"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogoDahuka" />

    <!-- Đường kẻ xanh trên -->
    <View
        android:id="@+id/viewLineTop"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="#47B649"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTenLogo" />

    <!-- Khung trắng bo góc -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDangKy"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewLineTop"
        app:strokeColor="#E7E7E7"
        app:strokeWidth="1dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="22dp"
                android:paddingEnd="22dp"
                android:paddingBottom="30dp">

                <TextView
                    android:id="@+id/txtTieuDeDangKy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng Ký"
                    android:textColor="#1F2A3D"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtMoTa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Nhập số điện thoại để đăng ký &amp; nhận mã OTP để xác nhận"
                    android:textColor="#8D94A3"
                    android:textSize="14sp" />

                <!-- Ô nhập số điện thoại -->
                <LinearLayout
                    android:id="@+id/khungNhapSdt"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/o_nhap_sdt"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="0dp"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:id="@+id/khuVucMaQuocGia"
                        android:layout_width="88dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtMaQuocGia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="84"
                            android:textColor="#97A0AF"
                            android:textSize="16sp" />

                        <ImageView
                            android:id="@+id/imgMuiTen"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="Chon ma quoc gia"
                            android:src="@android:drawable/arrow_down_float"
                            android:tint="#B8BEC9" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:background="#E2E5EA" />

                    <EditText
                        android:id="@+id/edtSoDienThoai"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Số điện thoại"
                        android:inputType="phone"
                        android:paddingStart="12dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="16sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnTiepTuc"
                    android:layout_width="164dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/nut_tiep_tuc"
                    android:text="Tiếp tục"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtHoac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="Hoặc"
                    android:textColor="#5B6473"
                    android:textSize="16sp" />

                <!-- Dòng kẻ + chữ -->
                <LinearLayout
                    android:id="@+id/khuVucKhac"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#D9DDE3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="ĐĂNG NHẬP BẰNG HÌNH THỨC KHÁC"
                        android:textColor="#7A8393"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#D9DDE3" />
                </LinearLayout>

                <!-- Nút Google -->
                <LinearLayout
                    android:id="@+id/btnDangNhapGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="28dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginEnd="28dp"
                    android:background="@drawable/nut_dang_nhap_google"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:id="@+id/imgGoogle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Google"
                        android:src="@drawable/ic_google" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="18dp"
                        android:layout_marginEnd="18dp"
                        android:background="#D9DDE3" />

                    <TextView
                        android:id="@+id/txtGoogle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng nhập với Google"
                        android:textColor="#334155"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>