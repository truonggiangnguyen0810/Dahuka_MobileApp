<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F7F7">

    <!-- Header logo -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:src="@drawable/logo_dahuka"
            android:scaleType="fitCenter" />
    </RelativeLayout>

    <!-- Green line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E7D32" />

    <!-- Main card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        android:background="@drawable/bg_register_box"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Title -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác minh số điện thoại"
            android:textColor="#1F2937"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Description -->
        <TextView
            android:id="@+id/txtDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Nhập số điện thoại để đăng ký &amp; nhận mã OTP để xác nhận"
            android:textColor="#9CA3AF"
            android:textSize="14sp" />

        <!-- Phone input row -->
        <LinearLayout
            android:id="@+id/layoutPhoneInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_input_phone"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Country code -->
            <LinearLayout
                android:layout_width="70dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtCountryCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="84"
                    android:textColor="#9CA3AF"
                    android:textSize="18sp" />

                <ImageView
                    android:id="@+id/imgArrow"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/arrow_down_float" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#E5E7EB" />

            <EditText
                android:id="@+id/edtPhone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Số điện thoại"
                android:inputType="phone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Continue button -->
        <Button
            android:id="@+id/btnTiepTuc"
            android:layout_width="132dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_continue"
            android:text="Tiếp tục"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Or -->

        <!-- Divider with text -->

        <!-- Google login -->

    </LinearLayout>

</LinearLayout>