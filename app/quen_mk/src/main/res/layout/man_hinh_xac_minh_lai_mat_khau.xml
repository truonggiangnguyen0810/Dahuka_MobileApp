<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F6F6">

    <include layout="@layout/taskbar" />


    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2F8F46" />

    <!-- Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        android:background="@drawable/bg_register_box"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vui lòng nhập mã xác minh"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- OTP -->

        <!-- Password 1 -->
        <LinearLayout
            android:id="@+id/layoutPassword"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_input_phone"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgLock1"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="14dp"
                android:src="@drawable/icon_lock" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginStart="12dp"
                android:background="#E5E7EB" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Nhập mật khẩu mới"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#374151"
                android:textColorHint="#374151"
                android:textSize="16sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:background="#E5E7EB" />

            <ImageView
                android:id="@+id/imgShowPass1"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_eye" />
        </LinearLayout>

        <!-- Password 2 -->
        <LinearLayout
            android:id="@+id/layoutRePassword"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_phone"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgLock2"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="14dp"
                android:src="@drawable/icon_lock" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginStart="12dp"
                android:background="#E5E7EB" />

            <EditText
                android:id="@+id/edtRePassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Nhập lại mật khẩu mới"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="#374151"
                android:textColorHint="#374151"
                android:textSize="16sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:background="#E5E7EB" />

            <ImageView
                android:id="@+id/imgShowPass2"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_eye" />
        </LinearLayout>

        <Button
            android:id="@+id/btnXacNhan"
            android:layout_width="132dp"
            android:layout_height="42dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_continue"
            android:text="Xác nhận"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="* Lưu ý: Mật khẩu tối thiểu mười (10) ký tự, ít nhất một chữ cái viết hoa, một chữ cái viết thường, một số và một ký tự đặc biệt (@$!%*?&amp;)."
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

</LinearLayout>