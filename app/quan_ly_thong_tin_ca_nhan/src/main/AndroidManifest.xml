<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Quanlytaikhoan">
        <activity
            android:name=".quanlytaikhoan.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".quanlytaikhoan.PersonalInfoActivity"
            android:exported="false" />

        <activity
            android:name=".quanlytaikhoan.PurchaseHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".quanlytaikhoan.ChangePasswordActivity"
            android:exported="false" />

        <activity
            android:name=".quanlytaikhoan.OrderDetailActivity"
            android:exported="false" />
    </application>

</manifest>
