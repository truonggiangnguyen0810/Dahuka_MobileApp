<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:background="@drawable/nen_popup_quen_mat_khau"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="26dp"
    android:paddingEnd="24dp"
    android:paddingBottom="26dp">

    <TextView
        android:id="@+id/txtTieuDePopupQuenMk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quên mật khẩu ?"
        android:textColor="#1F2A3D"
        android:textSize="24sp"
        android:textStyle="normal" />

    <TextView
        android:id="@+id/txtMoTaPopupQuenMk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Vui lòng nhập số điện thoại để lấy lại mật khẩu"
        android:textColor="#8D94A3"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/khungNhapSdtPopupQuenMk"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/o_nhap_popup_quen_mat_khau"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:id="@+id/imgIconNguoiDungPopup"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="So dien thoai"
            android:src="@drawable/ic_ho_ten" />

        <View
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:background="#E2E5EA" />

        <EditText
            android:id="@+id/edtSoDienThoaiQuenMk"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Số điện thoại"
            android:inputType="phone"
            android:textColor="#1F2A3D"
            android:textColorHint="#A4ACB9"
            android:textSize="16sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnXacNhanPopupQuenMk"
        android:layout_width="140dp"
        android:layout_height="40dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/nut_xac_nhan_popup_quen_mk"
        android:text="Xác nhận"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>