<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Logo -->
    <ImageView
        android:id="@+id/imgLogoDahuka"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:contentDescription="Logo DAHUKA"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_dahuka"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTenLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text=""
        android:textColor="#007A5A"
        android:textSize="0sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogoDahuka" />

    <View
        android:id="@+id/viewLineTop"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="#47B649"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTenLogo" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardQuenMatKhau"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewLineTop"
        app:strokeColor="#E7E7E7"
        app:strokeWidth="1dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="20dp"
                android:paddingEnd="22dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/txtTieuDe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vui lòng nhập mã xác minh"
                    android:textColor="#1F2A3D"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtMoTaOtp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Mã OTP của bạn đã được gửi bằng tin nhắn đến (+84) ..."
                    android:textColor="#8D94A3"
                    android:textSize="14sp" />

                <!-- 6 ô OTP -->
                <LinearLayout
                    android:id="@+id/khuVucOtp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtOtp1"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/o_nhap_otp"
                        android:gravity="center"
                        android:hint="."
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="20sp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/edtOtp2"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/o_nhap_otp"
                        android:gravity="center"
                        android:hint="."
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="20sp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/edtOtp3"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/o_nhap_otp"
                        android:gravity="center"
                        android:hint="."
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="20sp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/edtOtp4"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/o_nhap_otp"
                        android:gravity="center"
                        android:hint="."
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="20sp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/edtOtp5"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/o_nhap_otp"
                        android:gravity="center"
                        android:hint="."
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="20sp" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/edtOtp6"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/o_nhap_otp"
                        android:gravity="center"
                        android:hint="."
                        android:inputType="number"
                        android:maxLength="1"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="20sp" />
                </LinearLayout>

                <!-- Mật khẩu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="34dp"
                    android:background="@drawable/o_nhap_quen_mk"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Mat khau"
                        android:src="@drawable/ic_mat_khau" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="12dp"
                        android:background="#E2E5EA" />

                    <EditText
                        android:id="@+id/edtMatKhauMoi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Mật khẩu"
                        android:inputType="textPassword"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:background="#E2E5EA" />

                    <ImageView
                        android:id="@+id/imgAnHienMatKhau"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="An hien mat khau"
                        android:src="@drawable/ic_mat_xem" />
                </LinearLayout>

                <!-- Xác nhận mật khẩu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/o_nhap_quen_mk"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Xac nhan mat khau"
                        android:src="@drawable/ic_mat_khau" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="12dp"
                        android:background="#E2E5EA" />

                    <EditText
                        android:id="@+id/edtXacNhanMatKhau"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Xác nhận mật khẩu"
                        android:inputType="textPassword"
                        android:textColor="#1F2A3D"
                        android:textColorHint="#A4ACB9"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="22dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:background="#E2E5EA" />

                    <ImageView
                        android:id="@+id/imgAnHienXacNhanMatKhau"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="An hien xac nhan mat khau"
                        android:src="@drawable/ic_mat_xem" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnXacNhan"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/nut_xac_nhan_quen_mk"
                    android:text="Xác nhận"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtGuiLaiMa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:text="Gửi lại mã sau: 04:49"
                    android:textColor="#5B6473"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtLuuY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="* Lưu ý : Mật khẩu tối thiểu mười (10) ký tự, ít nhất một chữ cái viết hoa, một chữ cái viết thường, một số và một ký tự đặc biệt (@$!%*?&amp;)."
                    android:textColor="#6B7280"
                    android:textSize="13sp" />

                <Space
                    android:layout_width="1dp"
                    android:layout_height="130dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Hoặc"
                    android:textColor="#5B6473"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#D9DDE3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="ĐĂNG NHẬP BẰNG HÌNH THỨC KHÁC"
                        android:textColor="#7A8393"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#D9DDE3" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnDangNhapGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="30dp"
                    android:background="@drawable/nut_dang_nhap_google"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Google"
                        android:src="@drawable/ic_google" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="18dp"
                        android:layout_marginEnd="18dp"
                        android:background="#D9DDE3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng nhập với Google"
                        android:textColor="#334155"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>