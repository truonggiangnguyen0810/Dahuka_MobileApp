<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9D9D9"
    tools:context=".ManHinhDanhSachSanPhamActivity">

    <LinearLayout
        android:id="@+id/contentMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include layout="@layout/taskbar" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgBanner"
                    android:layout_width="match_parent"
                    android:layout_height="204dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/banner_may_loc_nuoc" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tvBreadcrumb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trang chủ / Máy lọc nước"
                        android:textColor="#2F2F2F"
                        android:textSize="13sp" />

                    <!-- [START] Hàng nút lọc + sắp xếp (clipChildren=false để dropdown vượt ra ngoài) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:clipChildren="false"
                        android:orientation="horizontal">



                        <FrameLayout
                            android:id="@+id/btnLoc"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/ic_filter"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="7dp" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- [START] Dropdown sắp xếp -->
                        <FrameLayout
                            android:id="@+id/btnSapXep"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:clipChildren="false">

                            <LinearLayout
                                android:id="@+id/sortPill"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_sort_pill"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="14dp"
                                android:paddingEnd="10dp"
                                android:minWidth="160dp">

                                <TextView
                                    android:id="@+id/tvSortLabel"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Mới nhất"
                                    android:textColor="#0A7A58"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/imgSortArrow"
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_arrow_down" />
                            </LinearLayout>

                        </FrameLayout>
                        <!-- [END] Dropdown sắp xếp -->
                    </LinearLayout>
                    <!-- [END] Hàng nút lọc + sắp xếp -->

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSanPham"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="2"
                        tools:listitem="@layout/item_san_pham" />

                    <TextView
                        android:id="@+id/tvKhongTimThay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp"
                        android:gravity="center"
                        android:text="Không tìm thấy sản phẩm phù hợp"
                        android:textColor="#666666"
                        android:textSize="16sp"
                        android:visibility="gone" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="170dp">

                    <ImageView
                        android:id="@+id/imgFooterBanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banner_footer_store" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#33000000" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top"
                        android:layout_marginStart="28dp"
                        android:layout_marginTop="26dp"
                        android:layout_marginEnd="28dp"
                        android:text="“Hãy đến và trải nghiệm sản phẩm Mutosi mới nhất tại các cửa hàng của chúng tôi”"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="italic" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal|bottom"
                        android:layout_marginBottom="40dp"
                        android:text="Khám phá ngay"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Giới thiệu Mutosi"
                                android:textColor="#3A3A3A"
                                android:textSize="15sp"
                                android:textStyle="italic" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:lineSpacingExtra="1dp"
                                android:text="· Giới thiệu về Mutosi&#10;· Trách nhiệm xã hội&#10;· Tin tuyển dụng&#10;· Liên hệ"
                                android:textColor="#4D4D4D"
                                android:textSize="12sp"
                                android:textStyle="italic" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tin tức"
                                android:textColor="#3A3A3A"
                                android:textSize="15sp"
                                android:textStyle="italic" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:lineSpacingExtra="1dp"
                                android:text="· Giải pháp nước sạch&#10;· Tư vấn gia dụng&#10;· Hướng dẫn lắp đặt"
                                android:textColor="#4D4D4D"
                                android:textSize="12sp"
                                android:textStyle="italic" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chính sách mua hàng"
                                android:textColor="#3A3A3A"
                                android:textSize="15sp"
                                android:textStyle="italic" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:lineSpacingExtra="1dp"
                                android:text="· Chính sách lắp đặt&#10;· Chính sách giao hàng&#10;· Chính sách đổi trả hàng&#10;· Chính sách bảo hành&#10;· Chính sách bảo mật&#10;· Phương thức thanh toán&#10;· Chính sách kiểm hàng&#10;· Chính sách xử lý khiếu nại&#10;· Điều kiện và điều khoản sử dụng"
                                android:textColor="#4D4D4D"
                                android:textSize="12sp"
                                android:textStyle="italic" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hỗ trợ khách hàng - Đại lý"
                                android:textColor="#3A3A3A"
                                android:textSize="15sp"
                                android:textStyle="italic" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:lineSpacingExtra="1dp"
                                android:text="· Đăng ký bảo hành&#10;· Đăng ký đổi tác&#10;· Tra cứu mua hàng&#10;· FAQ&#10;· Sitemap"
                                android:textColor="#4D4D4D"
                                android:textSize="12sp"
                                android:textStyle="italic" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hotline&#10;1900 636 567"
                            android:textColor="#4D4D4D"
                            android:textSize="12sp"
                            android:textStyle="italic" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hỗ trợ xử lý sự cố&#10;1900 636 596"
                            android:textColor="#4D4D4D"
                            android:textSize="12sp"
                            android:textStyle="italic" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Email&#10;cskh@dahuka.com"
                            android:textColor="#4D4D4D"
                            android:textSize="12sp"
                            android:textStyle="italic" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Bản quyền thuộc về Công ty Dahuka"
                        android:textColor="#4D4D4D"
                        android:textSize="12sp"
                        android:textStyle="italic" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Văn phòng đại diện:&#10;644 Nguyễn Hữu Thọ, Khuê Trung, Cẩm Lệ, Đà Nẵng"
                            android:textColor="#4D4D4D"
                            android:textSize="12sp"
                            android:textStyle="italic" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="Tư vấn mua hàng&#10;1900 636 053"
                            android:textColor="#4D4D4D"
                            android:textSize="12sp"
                            android:textStyle="italic" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:background="#001219"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/logo_dahuka" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:text="Nâng tầm sống khỏe chuẩn Nhật"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="italic" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <View
        android:id="@+id/overlayDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- [START] Panel lọc: căn trái + giữa dọc + nổi lên với elevation -->
    <LinearLayout
        android:id="@+id/layoutSortOptions"
        android:layout_width="170dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_sort_dropdown_white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/optionMoiNhat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:text="Mới nhất"
            android:textColor="#222222"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/optionGiaTang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:text="Giá thấp đến cao"
            android:textColor="#222222"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/optionGiaGiam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:text="Giá cao đến thấp"
            android:textColor="#222222"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelLoc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:visibility="gone"
        android:elevation="8dp">

        <include layout="@layout/loc" />
    </LinearLayout>
    <!-- [END] Panel lọc -->

    <FrameLayout
        android:id="@+id/menuContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="12dp"
        android:visibility="gone" />

</FrameLayout>