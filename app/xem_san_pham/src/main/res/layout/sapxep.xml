<?xml version="1.0" encoding="utf-8"?>

<!--
    DROPDOWN SẮP XẾP
    - Gồm 2 phần:
    1. Thanh tiêu đề đang chọn
    2. Danh sách lựa chọn xổ xuống
    - Bản này chỉ làm giao diện trước, chưa xử lý click
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutSortDropdown"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ===================== THANH ĐANG CHỌN ===================== -->
    <!--
        Đây là phần luôn nhìn thấy:
        - text "Mới nhất"
        - icon mũi tên
    -->
    <LinearLayout
        android:id="@+id/layoutSortHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_sort_pill"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="12dp">

        <!-- Nội dung đang chọn -->
        <TextView
            android:id="@+id/tvSortSelected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mới nhất"
            android:textColor="#0A7A58"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Icon mũi tên -->
        <ImageView
            android:id="@+id/imgSortArrow"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_arrow_down" />
    </LinearLayout>

    <!-- Khoảng cách nhỏ giữa header và panel -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <!-- ===================== DANH SÁCH DROPDOWN ===================== -->
    <!--
        Khung nền trắng chứa các lựa chọn sắp xếp
    -->
    <LinearLayout
        android:id="@+id/layoutSortOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_sort_dropdown_white"
        android:elevation="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Option 1 -->
        <TextView
            android:id="@+id/optionMoiNhat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:text="Mới nhất"
            android:textColor="#222222"
            android:textSize="14sp" />

        <!-- Option 2 -->

        <!-- Option 3 -->
        <TextView
            android:id="@+id/optionGiaTang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:text="Giá thấp đến cao"
            android:textColor="#222222"
            android:textSize="14sp" />

        <!-- Option 4 -->
        <TextView
            android:id="@+id/optionGiaGiam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:text="Giá cao đến thấp"
            android:textColor="#222222"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>