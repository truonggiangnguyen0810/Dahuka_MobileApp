<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/taskbar" />

    <!-- Title GIỎ HÀNG -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:background="#333333"
            android:layout_marginEnd="12dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GIỎ HÀNG"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A202C" />
        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:background="#333333"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/containerProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Thông tin nhận hàng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Thông Tin Nhận Hàng"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2D3748" />
                        <ImageButton
                            android:id="@+id/btnChinhSuaDiaChi"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_menu_edit"
                            android:contentDescription="Chỉnh sửa"
                            app:tint="#A0AEC0" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvTenSoDienThoai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="An Nguyễn Văn | 0349434960 |"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#2D3748"
                        android:layout_marginTop="6dp" />
                    <TextView
                        android:id="@+id/tvDiaChiNhanHang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="68 Dương Khuê, Phường Phước Mỹ, Quận Sơn Trà, Thành phố Đà Nẵng"
                        android:textSize="12sp"
                        android:textColor="#718096"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:elevation="8dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvTongSanPham"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng cộng 0 sản phẩm"
                android:textSize="12sp"
                android:textColor="#A0AEC0" />
            <TextView
                android:id="@+id/tvTongTien"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textSize="18sp"
                android:textColor="#E53E3E"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMuaNgay"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:text="MUA NGAY →"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#0F764E"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>
