<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Toolbar DAHUKA -->
    <include layout="@layout/include_toolbar" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:background="#333333"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Title GIỎ HÀNG with lines -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:background="#333333"
            android:layout_marginEnd="16dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GIỎ HÀNG"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A202C" />
        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:background="#333333"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Thông tin nhận hàng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Thông Tin Nhận Hàng"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2D3748" />
                        <ImageButton
                            android:id="@+id/btnChinhSuaDiaChi"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_menu_edit"
                            android:tint="#A0AEC0"
                            android:contentDescription="Chỉnh sửa" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="An Nguyễn Văn | 0349434960 |"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#2D3748"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="68 Dương Khuê, Phường Phước Mỹ, Quận Sơn Trà, Thành phố Đà Nẵng"
                        android:textSize="13sp"
                        android:textColor="#718096"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProduct1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#CBD5E0" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="100dp"
                        android:src="@drawable/anhsanpham"
                        android:scaleType="fitCenter"
                        android:layout_marginStart="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Máy Lọc Nước RO 12 Cấp Mutosi MP-S126"
                            android:textSize="14sp"
                            android:textColor="#2D3748"
                            android:lineSpacingExtra="2dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/bg_qty_border"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="-" android:textSize="18sp" android:textColor="#718096" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="1" android:textSize="15sp" android:textColor="#2D3748" android:textStyle="bold"
                                    android:layout_marginStart="12dp" android:layout_marginEnd="12dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="+" android:textSize="18sp" android:textColor="#718096" />
                            </LinearLayout>

                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5.990.000"
                                android:textSize="16sp"
                                android:textColor="#E53E3E"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/btnDelete1"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_delete"
                                android:tint="#90CDF4"
                                android:layout_marginStart="12dp"
                                android:contentDescription="Xóa" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProduct2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#CBD5E0" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="100dp"
                        android:src="@drawable/anhsanpham"
                        android:scaleType="fitCenter"
                        android:layout_marginStart="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Máy lọc nước điện giải ion kiềm Hydrogen MP-S1021H"
                            android:textSize="14sp"
                            android:textColor="#2D3748"
                            android:lineSpacingExtra="2dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/bg_qty_border"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="-" android:textSize="18sp" android:textColor="#718096" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="1" android:textSize="15sp" android:textColor="#2D3748" android:textStyle="bold"
                                    android:layout_marginStart="12dp" android:layout_marginEnd="12dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="+" android:textSize="18sp" android:textColor="#718096" />
                            </LinearLayout>

                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5.990.000"
                                android:textSize="16sp"
                                android:textColor="#E53E3E"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/btnDelete2"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_delete"
                                android:tint="#90CDF4"
                                android:layout_marginStart="12dp"
                                android:contentDescription="Xóa" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Product 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProduct3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <RadioButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#CBD5E0" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="100dp"
                        android:src="@drawable/anhsanpham"
                        android:scaleType="fitCenter"
                        android:layout_marginStart="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Máy Lọc Nước RO 12 Cấp Mutosi MP-S126"
                            android:textSize="14sp"
                            android:textColor="#2D3748"
                            android:lineSpacingExtra="2dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/bg_qty_border"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="-" android:textSize="18sp" android:textColor="#718096" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="1" android:textSize="15sp" android:textColor="#2D3748" android:textStyle="bold"
                                    android:layout_marginStart="12dp" android:layout_marginEnd="12dp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="+" android:textSize="18sp" android:textColor="#718096" />
                            </LinearLayout>

                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5.990.000"
                                android:textSize="16sp"
                                android:textColor="#E53E3E"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/btnDelete3"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_delete"
                                android:tint="#90CDF4"
                                android:layout_marginStart="12dp"
                                android:contentDescription="Xóa" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng cộng 2 sản phẩm"
                android:textSize="13sp"
                android:textColor="#A0AEC0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11.980.000"
                android:textSize="20sp"
                android:textColor="#E53E3E"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMuaNgay"
            android:layout_width="wrap_content"
            android:layout_height="54dp"
            android:text="MUA NGAY  →"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#0F764E"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
