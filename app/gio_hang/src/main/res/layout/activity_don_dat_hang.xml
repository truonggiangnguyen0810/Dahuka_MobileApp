<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2">

    <!-- Toolbar: back + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#111111"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ĐƠN ĐẶT HÀNG"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:gravity="center"
            android:layout_marginEnd="48dp" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="14dp"
            android:paddingBottom="8dp">

            <!-- CHI TIẾT ĐƠN HÀNG -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHI TIẾT ĐƠN HÀNG"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginBottom="10dp" />

            <!-- Container render động từ GioHangActivity -->
            <LinearLayout
                android:id="@+id/containerOrderItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- PHƯƠNG THỨC THANH TOÁN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHƯƠNG THỨC THANH TOÁN"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginBottom="10dp" />

            <!-- Chuyển khoản (selected) -->
            <LinearLayout
                android:id="@+id/layoutChuyenKhoan"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_payment_selected"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_payment_icon">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_upload"
                        android:tint="#E07B00"
                        android:layout_gravity="center"
                        android:contentDescription="Chuyển khoản" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chuyển khoản"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:layout_marginStart="14dp" />

                <RadioButton
                    android:id="@+id/rbChuyenKhoan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:buttonTint="@color/green_primary" />
            </LinearLayout>

            <!-- Tiền mặt -->
            <LinearLayout
                android:id="@+id/layoutTienMat"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_payment_normal">

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_payment_icon">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_save"
                        android:tint="#888888"
                        android:layout_gravity="center"
                        android:contentDescription="Tiền mặt" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tiền mặt"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:layout_marginStart="14dp" />

                <RadioButton
                    android:id="@+id/rbTienMat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:buttonTint="@color/green_primary" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Tạm tính + Phí vận chuyển + Divider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tạm tính:"
                android:textSize="14sp"
                android:textColor="#555555" />
            <TextView
                android:id="@+id/tvTamTinh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11.980.000đ"
                android:textSize="14sp"
                android:textColor="#111111" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Phí vận chuyển:"
                android:textSize="14sp"
                android:textColor="#555555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Miễn phí"
                android:textSize="14sp"
                android:textColor="@color/green_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />
    </LinearLayout>

    <!-- Bottom button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnXacNhan"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="XÁC NHẬN ĐẶT HÀNG →"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:backgroundTint="@color/green_primary"
            app:cornerRadius="28dp" />
    </LinearLayout>

</LinearLayout>
