<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <include layout="@layout/include_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. Success section: nền trắng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="32dp"
                android:paddingBottom="20dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:background="#FFFFFF">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_success_icon"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="30sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_gravity="center" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đặt hàng thành công"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cảm ơn vì đã mua hàng !"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/btnTrangChu"
                        android:layout_width="130dp"
                        android:layout_height="44dp"
                        android:text="Trang chủ"
                        android:textSize="14sp"
                        android:textColor="#2ECC71"
                        android:gravity="center"
                        android:background="@drawable/bg_btn_outline_green"
                        android:layout_marginEnd="12dp" />
                    <TextView
                        android:id="@+id/btnXemGioHang"
                        android:layout_width="130dp"
                        android:layout_height="44dp"
                        android:text="Xem giỏ hàng"
                        android:textSize="14sp"
                        android:textColor="#2ECC71"
                        android:gravity="center"
                        android:background="@drawable/bg_btn_outline_green" />
                </LinearLayout>
            </LinearLayout>

            <!-- 2. Banner ảnh cửa hàng + overlay + text -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <ImageView
                    android:id="@+id/imgBanner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/anhfooter"
                    android:scaleType="centerCrop"
                    android:contentDescription="Banner Mutosi" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#88000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&quot;Hãy đến và trải nghiệm sản phẩm Dahuka mới nhất tại các cửa hàng của chúng tôi&quot;"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />
                    <TextView
                        android:id="@+id/btnKhamPha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="“Hãy đến và trải nghiệm sản phẩm Dahuka mới nhất tại các cửa hàng của chúng tôi”"
                        android:textSize="13sp"
                        android:textColor="#CCCCCC" />
                </LinearLayout>
            </FrameLayout>

            <!-- 3. Footer links: nền trắng, chữ tối -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="#FFFFFF">

                <!-- Left column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Giới thiệu Mutosi" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#333333" android:layout_marginBottom="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Giới thiệu về Mutosi" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Trách nhiệm xã hội" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Tin tuyển dụng" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Liên hệ" android:textSize="11sp" android:textColor="#555555"
                        android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Chính sách mua hàng" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#333333" android:layout_marginBottom="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Chính sách lắp đặt" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Chính sách giao hàng" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Chính sách đổi trả hàng" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Chính sách bảo hành" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Chính sách bảo mật" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Phương thức thanh toán" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Chính sách kiểm hàng" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Chính sách xử lý khiếu nại" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Điều kiện và điều khoản sử dụng" android:textSize="11sp" android:textColor="#555555"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Hotline" android:textSize="11sp" android:textStyle="bold" android:textColor="#333333" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1900 636 567" android:textSize="11sp" android:textColor="#555555" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Hỗ trợ xử lý sự cố" android:textSize="11sp" android:textStyle="bold" android:textColor="#333333" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="1900 636 596" android:textSize="11sp" android:textColor="#555555" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bản quyền thuộc về Công ty Dahuka." android:textSize="10sp"
                        android:textColor="#888888" android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Right column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tin tức" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#333333" android:layout_marginBottom="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Giải pháp nước sạch" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Tư vấn gia dụng" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Hướng dẫn lắp đặt" android:textSize="11sp" android:textColor="#555555"
                        android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hỗ trợ khách hàng - Đại lý" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#333333" android:layout_marginBottom="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Đăng ký bảo hành" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Đăng ký đối tác" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Tra cứu mua hàng" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• FAQ" android:textSize="11sp" android:textColor="#555555" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Sitemap" android:textSize="11sp" android:textColor="#555555"
                        android:layout_marginBottom="8dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Email" android:textSize="11sp" android:textStyle="bold" android:textColor="#333333" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="cskh@dahuka.com" android:textSize="11sp" android:textColor="#555555" />
                </LinearLayout>
            </LinearLayout>

            <!-- 4. Address row: nền trắng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="#FFFFFF">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Văn phòng đại diện:" android:textSize="10sp" android:textStyle="bold" android:textColor="#333333" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="644 Nguyễn Hữu Thọ, Khuê Trung, Cẩm Lệ, Đà Nẵng"
                        android:textSize="10sp" android:textColor="#555555" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tư vấn mua hàng" android:textSize="10sp" android:textStyle="bold" android:textColor="#333333" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1900 636 053" android:textSize="10sp" android:textColor="#555555" />
                </LinearLayout>
            </LinearLayout>

            <!-- 5. Bottom dark bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A1A1A"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="Logo" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nâng tầm sống khỏe chuẩn Nhật"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
