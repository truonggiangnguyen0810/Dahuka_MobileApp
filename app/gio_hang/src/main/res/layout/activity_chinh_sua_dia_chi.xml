<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar: back + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/green_primary"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Địa chỉ mới"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- LIÊN HỆ section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIÊN HỆ"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ và tên"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etHoTen"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Nguyễn Văn An"
                    android:text="Nguyễn Văn An"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:textColorHint="#AAAAAA"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số điện thoại"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etSoDienThoai"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="0999777666"
                    android:text="0999777666"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:textColorHint="#AAAAAA"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="phone" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="#F0F0F0" />

            <!-- ĐỊA CHỈ section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐỊA CHỈ"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tỉnh/Thành phố, Quận/Huyện, Phường/Xã"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="6dp" />

                <!-- Dropdown style row -->
                <LinearLayout
                    android:id="@+id/layoutChonDiaChi"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tvDiaChi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phường Phú Quý, Quận Ngũ Hành, Đà Nẵng"
                        android:textSize="14sp"
                        android:textColor="#111111" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="20sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên đường, Toà nhà, Số nhà"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etTenDuong"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Đặng Hối Xuân"
                    android:text="Đặng Hối Xuân"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:textColorHint="#AAAAAA"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPostalAddress" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="#F0F0F0" />

            <!-- LOẠI ĐỊA CHỈ section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOẠI ĐỊA CHỈ"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- Nhà Riêng (selected) -->
                    <LinearLayout
                        android:id="@+id/layoutNhaRieng"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_address_type_selected"
                        android:layout_marginEnd="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⌂  Nhà Riêng"
                            android:textSize="14sp"
                            android:textColor="#1B7A4A"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Văn Phòng -->
                    <LinearLayout
                        android:id="@+id/layoutVanPhong"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_address_type_normal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗂  Văn Phòng"
                            android:textSize="14sp"
                            android:textColor="#555555" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Đặt làm địa chỉ mặc định -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đặt làm địa chỉ mặc định"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#111111" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sử dụng địa chỉ này cho các đơn hàng sau"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchMacDinh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="#FFFFFF"
                        android:trackTint="#CCCCCC" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="#F0F0F0" />

        </LinearLayout>
    </ScrollView>

    <!-- HOÀN THÀNH button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHoanThanh"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="HOÀN THÀNH"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            app:backgroundTint="@color/green_primary"
            app:cornerRadius="28dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>

</LinearLayout>
